{
  "groups": [
    {
      "title": "Default Content",
      "id": "default",
      "components": [
        {
          "title": "Text",
          "id": "text",
          "model": "text",
          "plugins": {
            "da": {
              "name": "text",
              "type": "text"
            }
          }
        },
        {
          "title": "Image",
          "id": "image",
          "model": "image",
          "plugins": {
            "da": {
              "name": "image",
              "type": "image",
              "fields": [
                {
                  "name": "image",
                  "selector": "picture > img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "picture > img[alt]"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "title": "Sections",
      "id": "sections",
      "components": [
        {
          "title": "Section",
          "id": "section",
          "plugins": {
            "da": {
              "unsafeHTML": "<div></div>"
            }
          },
          "filter": "section",
          "model": "section"
        }
      ]
    },
    {
      "title": "Blocks",
      "id": "blocks",
      "components": [
        {
          "title": "Cards",
          "id": "cards",
          "model": "cards",
          "filter": "cards",
          "plugins": {
            "da": {
              "rows": 1,
              "columns": 2
            }
          }
        },
        {
          "title": "Card",
          "id": "card",
          "model": "card",
          "plugins": {
            "da": {
              "rows": 1,
              "columns": 2,
              "fields": [
                {
                  "name": "image",
                  "selector": "div:nth-child(1) > picture > img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "div:nth-child(1) > picture > img[alt]"
                },
                {
                  "name": "text",
                  "selector": "div:nth-child(2)"
                }
              ]
            }
          }
        },
        {
          "title": "Cards Gallery",
          "id": "cards-gallery",
          "model": "cards-gallery",
          "filter": "cards-gallery",
          "plugins": {
            "da": {
              "name": "cards-gallery",
              "rows": 1,
              "columns": 2
            }
          }
        },
        {
          "title": "Gallery",
          "id": "cards-gallery-item",
          "model": "cards-gallery-item",
          "plugins": {
            "da": {
              "name": "cards-gallery-item",
              "rows": 1,
              "columns": 2,
              "fields": [
                {
                  "name": "thumbnail",
                  "selector": "div:nth-child(1) > picture > img[src]"
                },
                {
                  "name": "thumbnailAlt",
                  "selector": "div:nth-child(1) > picture > img[alt]"
                },
                {
                  "name": "caption",
                  "selector": "div:nth-child(2)"
                }
              ]
            }
          }
        },
        {
          "title": "Cards Swatch",
          "id": "cards-swatch",
          "model": "cards-swatch",
          "filter": "cards-swatch",
          "plugins": {
            "da": {
              "name": "cards-swatch",
              "rows": 1,
              "columns": 2
            }
          }
        },
        {
          "title": "Swatch",
          "id": "cards-swatch-item",
          "model": "cards-swatch-item",
          "plugins": {
            "da": {
              "name": "cards-swatch-item",
              "rows": 1,
              "columns": 2,
              "fields": [
                {
                  "name": "name",
                  "selector": "div:nth-child(1)"
                },
                {
                  "name": "hex",
                  "selector": "div:nth-child(2)>p"
                }
              ]
            }
          }
        },
        {
          "title": "Columns",
          "id": "columns",
          "model": "columns",
          "filter": "columns",
          "plugins": {
            "da": {
              "name": "columns",
              "rows": 1,
              "columns": 2,
              "behaviour": "columns"
            }
          }
        },
        {
          "title": "Columns Row",
          "id": "columns-row",
          "model": "columns-row",
          "filter": "columns-row",
          "plugins": {
            "da": {
              "name": "columns-row",
              "behaviour": "columns-row"
            }
          }
        },
        {
          "title": "Columns Cell",
          "id": "columns-cell",
          "model": "columns-cell",
          "filter": "columns-cell",
          "plugins": {
            "da": {
              "unsafeHTML": "<div></div>",
              "behaviour": "columns-cell"
            }
          }
        },
        {
          "title": "Columns Specimen",
          "id": "columns-specimen",
          "model": "columns-specimen",
          "plugins": {
            "da": {
              "name": "columns-specimen",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "description",
                  "selector": "div>div"
                }
              ]
            }
          }
        },
        {
          "title": "Embed Audio",
          "id": "embed-audio",
          "model": "embed-audio",
          "plugins": {
            "da": {
              "name": "embed-audio",
              "unsafeHTML": "<div class=\"embed-audio\"><div><div><a href=\"\">PLAY THEME</a></div></div></div>",
              "fields": [
                {
                  "name": "audioUrl",
                  "selector": "div > div > a[href]"
                },
                {
                  "name": "audioUrlText",
                  "selector": "div > div > a"
                }
              ]
            }
          }
        },
        {
          "title": "Fragment",
          "id": "fragment",
          "model": "fragment",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"fragment\"><div><div><p><a href=\"\">Fragment URL</a></p></div></div></div>",
              "fields": [
                {
                  "name": "url",
                  "selector": "div > div > p > a[href]"
                },
                {
                  "name": "urlText",
                  "selector": "div > div > p > a"
                }
              ]
            }
          }
        },
        {
          "title": "Footer",
          "id": "footer",
          "model": "footer",
          "plugins": {
            "da": {
              "name": "footer",
              "unsafeHTML": "<div class=\"footer\"></div>"
            }
          }
        },
        {
          "title": "Header",
          "id": "header",
          "model": "header",
          "plugins": {
            "da": {
              "name": "header",
              "unsafeHTML": "<div class=\"header\"></div>"
            }
          }
        },
        {
          "title": "Hero",
          "id": "hero",
          "model": "hero",
          "plugins": {
            "da": {
              "name": "hero",
              "unsafeHTML": "<div class=\"hero\"><div><div><picture><source type=\"image/webp\" srcset=\"\"><source type=\"image/jpeg\" srcset=\"\"><img loading=\"lazy\"></picture><h1></h1></div></div></div>",
              "fields": [
                {
                  "name": "image",
                  "selector": "div > div > picture > img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "div > div > picture > img[alt]"
                },
                {
                  "name": "text",
                  "selector": "div > div > h1"
                }
              ]
            }
          }
        },
        {
          "title": "Video Hero",
          "id": "video-hero",
          "model": "video-hero",
          "plugins": {
            "da": {
              "name": "video-hero",
              "unsafeHTML": "<div class=\"video-hero autoplay\"><div><div><a href=\"\">Video</a></div></div></div>",
              "columns": 1,
              "rows": 1,
              "fields": [
                {
                  "name": "videoUrl",
                  "selector": "div>div>p>a[href]"
                },
                {
                  "name": "videoUrlText",
                  "selector": "div>div>p>a"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
